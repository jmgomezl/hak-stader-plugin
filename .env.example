# ── Stader Plugin Configuration ──────────────────────────────────────────────
#
# Shorthand: set STADER_NETWORK to auto-load all mainnet or testnet defaults.
# Individual env vars override the network defaults.
#
# NOTE: Stader testnet is no longer active. Use mainnet for all live testing.

STADER_NETWORK=mainnet
# STADER_NETWORK=testnet

# Staking contract (where users send HBAR to stake)
# Mainnet: 0.0.1027588 | Testnet: 0.0.48247334 (inactive)
STADER_STAKING_CONTRACT_ID=0.0.1027588

# Undelegation contract (where HBAR waits during the unbonding period)
# Mainnet: 0.0.1027587 | Testnet: 0.0.48247333 (inactive)
STADER_UNDELEGATION_CONTRACT_ID=0.0.1027587

# HBARX liquid staking token (HTS)
# Mainnet: 0.0.834116 | Testnet: 0.0.48247328 (inactive)
STADER_HBARX_TOKEN_ID=0.0.834116

# Treasury account that holds staked HBAR for the protocol
# Mainnet: 0.0.1412503
STADER_TREASURY_ACCOUNT_ID=0.0.1412503

# Hedera Mirror Node base URL (used for exchange rate calculation)
# Mainnet: https://mainnet-public.mirrornode.hedera.com
# Testnet: https://testnet.mirrornode.hedera.com
STADER_MIRROR_NODE_BASE_URL=https://mainnet-public.mirrornode.hedera.com

# Gas limit for ContractExecuteTransaction (default: 2000000)
# STADER_GAS_LIMIT=2000000

# Max withdrawal index to poll when listing pending withdrawals (default: 20)
# STADER_MAX_WITHDRAWAL_INDEX=20
